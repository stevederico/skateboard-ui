{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": [
    "App.*",
    "index.*",
    "components",
    "hooks",
    "icons",
    "shadcn/ui",
    "shadcn/hooks",
    "shadcn/lib/utils.*",
    "shadcn/lib/cva.*",
    "shadcn/lib/clsx.*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "scripts",
    "shadcn/lib/base-ui",
    "shadcn/lib/tailwind-merge.js"
  ]
}
